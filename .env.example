# Copy to .env.local for local dev, and add the same two vars in your Vercel project settings.
# These come from your Supabase project: Settings > API.
# The anon/publishable key is safe to expose in a browser app (security is enforced by
# Row Level Security + auth, not by hiding this key).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
